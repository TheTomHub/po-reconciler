# Vercel environment variables for Chandlr license API
#
# LICENSES is a JSON string mapping license keys to tier names.
# Tiers: "free" | "pro" | "enterprise"
#
# Set this in the Vercel dashboard under Project → Settings → Environment Variables.
# Do NOT commit real license keys to source control.
#
# Example:
LICENSES={"your-pro-key-here":"pro","your-enterprise-key-here":"enterprise"}
